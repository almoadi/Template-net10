{
  // Account security settings. Every flag is OFF by default — turning one on is opt-in.
  "Auth": {
    "RequireEmailVerification": false,   // Block login until the user verifies their email.
    "TwoFactorEnabled": false,           // Require an email OTP as a second login step.
    "OtpLength": 6,                      // Digits in a two-factor OTP code.
    "OtpExpiryMinutes": 10,             // OTP lifetime.
    "EmailVerificationExpiryHours": 24, // Email-verification token lifetime.
    "PasswordResetExpiryMinutes": 30    // Password-reset token lifetime.
  }
}
